#: src/Form/ScheduledActionEditForm.php:67
#: src/Form/ScheduledActionBatchUpdateForm.php:39
msgid "Day of month"
msgstr "Jour du mois"

#: src/Form/ScheduledActionEditForm.php:68
#: src/Form/ScheduledActionBatchUpdateForm.php:40
msgid ""
"The day of month at which the action will be run. Can be any valid cron "
"expression, for instance: \"1\", \"1-10\", \"*/5\", \"1,11,21\"."
msgstr ""
"Le jour du mois durant lequel l'action sera exécutée. Peut être n'importe "
"quelle expression cron valide, par exemple: \"1\", \"1-10\", \"*/5\", "
"\"1,11,21\"."

#: src/Form/ScheduledActionEditForm.php:80
#: src/Form/ScheduledActionBatchUpdateForm.php:51
msgid "Month"
msgstr "Mois"

#: src/Form/ScheduledActionEditForm.php:81
#: src/Form/ScheduledActionBatchUpdateForm.php:52
msgid ""
"The month at which the action will be run. Can be any valid cron expression, "
"for instance: \"1\", \"2-6\", \"*/2\", \"3,6,9\"."
msgstr ""
"Le mois durant lequel l'action sera exécutée. Peut être n'importe quelle "
"expression cron valide, par exemple: \"1\", \"2-6\", \"*/2\", \"3,6,9\"."

#: src/Form/ScheduledActionEditForm.php:93
#: src/Form/ScheduledActionBatchUpdateForm.php:63
msgid "Day of week"
msgstr "Jour de la semaine"

#: src/Form/ScheduledActionEditForm.php:94
#: src/Form/ScheduledActionBatchUpdateForm.php:64
msgid ""
"The day of week at which the action will be run. Can be any valid cron "
"expression, for instance: \"0\", \"1-5\", \"*/2\", \"0,6\". 0 is Sunday."
msgstr ""
"Le jour de la semaine durant lequel l'action sera exécutée. Peut être "
"n'importe quelle expression cron valide, par exemple: \"0\", \"1-5\", \"*/"
"2\", \"0,6\". 0 correspond à dimanche."

